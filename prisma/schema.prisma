model Location {
  id            String          @id @default(cuid())
  name          String
  shortCode     String
  type          LocationType    @default(INTERNAL)
  parentId      String?
  warehouseId   String?
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  parent        Location?       @relation("LocationHierarchy", fields: [parentId], references: [id])
  children      Location[]      @relation("LocationHierarchy")
  user          User            @relation(fields: [userId], references: [id])
  warehouse     Warehouse?      @relation(fields: [warehouseId], references: [id])
  stockLevels   StockLevel[]
  movesTo       StockMove[]     @relation("DestinationLocation")
  movesFrom     StockMove[]     @relation("SourceLocation")
  transfersTo   StockTransfer[] @relation("DestinationLocation")
  transfersFrom StockTransfer[] @relation("SourceLocation")

  @@unique([shortCode, userId])
}

model StockLevel {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  quantity   Int      @default(0)
  userId     String
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([productId, locationId])
}

model Contact {
  id              String           @id @default(cuid())
  name            String
  email           String?
  phone           String?
  type            ContactType      @default(CUSTOMER)
  address         String?
  userId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
  transfers       StockTransfer[]
  supplierProfile SupplierProfile?
}

model StockTransfer {
  id                    String         @id @default(cuid())
  reference             String
  origin                String?
  type                  TransferType
  status                TransferStatus @default(DRAFT)
  sourceLocationId      String?
  destinationLocationId String?
  contactId             String?
  scheduledDate         DateTime?
  effectiveDate         DateTime?
  userId                String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  stockMoves            StockMove[]
  contact               Contact?       @relation(fields: [contactId], references: [id])
  destinationLocation   Location?      @relation("DestinationLocation", fields: [destinationLocationId], references: [id])
  sourceLocation        Location?      @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  user                  User           @relation(fields: [userId], references: [id])

  @@unique([reference, userId])
}

model StockMove {
  id                    String         @id @default(cuid())
  transferId            String?
  productId             String
  quantity              Int
  sourceLocationId      String?
  destinationLocationId String?
  status                TransferStatus @default(DRAFT)
  userId                String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  destinationLocation   Location?      @relation("DestinationLocation", fields: [destinationLocationId], references: [id])
  product               Product        @relation(fields: [productId], references: [id])
  sourceLocation        Location?      @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  transfer              StockTransfer? @relation(fields: [transferId], references: [id])
  user                  User           @relation(fields: [userId], references: [id])
}

model SupplierProfile {
  id               String   @id @default(cuid())
  contactId        String   @unique
  leadTimeDays     Int      @default(3)
  reliabilityScore Float    @default(0.9)
  priceModifier    Float    @default(1.0)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  pageIndexTreeId  String?
  contact          Contact  @relation(fields: [contactId], references: [id])
  user             User     @relation(fields: [userId], references: [id])
}

model AgentAuditLog {
  id              String   @id @default(cuid())
  traceId         String
  nodeName        String
  inputData       Json
  outputData      Json
  reasoningString String
  decision        String
  userId          String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  MANAGER
  STOCK_MASTER
  STAFF
}

enum ProductType {
  STORABLE
  CONSUMABLE
  SERVICE
}

enum LocationType {
  VIEW
  INTERNAL
  CUSTOMER
  VENDOR
  INVENTORY_LOSS
  PRODUCTION
  TRANSIT
}

enum TransferType {
  INCOMING
  OUTGOING
  INTERNAL
  ADJUSTMENT
}

enum TransferStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELED
}

enum ContactType {
  VENDOR
  CUSTOMER
}
